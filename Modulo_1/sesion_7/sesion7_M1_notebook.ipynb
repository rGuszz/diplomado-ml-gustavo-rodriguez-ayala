    "# ── Tarea 4: Reporte con groupby ────────────────────────────────────────────\n",
    "# Con groupby + .agg() calcula por nombre_ramo:\n",
    "# - polizas: count\n",
    "# - prima_total: sum\n",
    "# - prima_prom: mean\n",
    "# - siniest_total: sum\n",
    "# Agrega columna pct_cartera = prima del ramo / total * 100\n",
    "\n",
    "# Tu codigo aqui:\n",
    "reporte_por_ramo = cartera_unida.groupby(\"nombre_ramo\").agg(\n",
    "    polizas = (\"poliza\", \"count\"),\n",
    "    prima_total = (\"prima\", \"sum\"),\n",
    "    prima_prom = (\"prima\", \"mean\"),\n",
    "    siniest_total = (\"siniest\", \"sum\")\n",
    ").reset_index()\n",
    "\n",
    "# Calcular pct_cartera después de la agregación\n",
    "reporte_por_ramo[\"pct_cartera\"] = (reporte_por_ramo[\"prima_total\"] / reporte_por_ramo[\"prima_total\"].sum() * 100).round(1)\n",
    "\n",
    "print(reporte_por_ramo)"
   ]
