   ],
   "source": [
    "# ── Multiples columnas a la vez ──────────────────────────────────────────────\n",
    "resultado = cartera.groupby('ramo')[['prima','siniest']].sum()\n",
    "print(resultado)\n",
    "print()\n",
    "\n",
    "# ── Agrupar por multiples columnas ───────────────────────────────────────────\n",
    "# Crear grupo de edad primero\n",
    "cartera['g_edad'] = pd.cut(\n",
    "    cartera['edad'],\n",
    "    bins=[0,30,45,60,100],\n",
    "    labels=['18-30','31-45','46-60','61+']\n",
    ")\n",
    "\n",
    "print('Prima por ramo y grupo de edad:')\n",
    "print(cartera.groupby(['ramo','g_edad'])['prima'].sum())"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "3d786f86",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "    ramo  prima_total  pct_cartera\n",
      "0  Autos        12500         33.9\n",
      "1    GMM         7500         20.3\n",
      "2   Vida        16900         45.8\n"
     ]
    }
   ],
   "source": [
    "# ── reset_index: convertir el resultado a DataFrame normal ───────────────────\n",
    "# Por defecto, el resultado de groupby tiene la clave como index\n",
    "# reset_index() la convierte en columna normal\n",
    "\n",
    "resumen = (cartera\n",
    "    .groupby('ramo')['prima']\n",
    "    .sum()\n",
    "    .reset_index()\n",
    "    .rename(columns={'prima':'prima_total'})\n",
    ")\n",
    "\n",
    "# Ahora podemos agregar columna de porcentaje\n",
    "resumen['pct_cartera'] = (resumen['prima_total'] / resumen['prima_total'].sum() * 100).round(1)\n",
    "\n",
    "print(resumen.to_string())"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "ae7bde8b",
   "metadata": {},
   "source": [
    "---\n",
    "<a id='2-agg'></a>\n",
    "## 2. .agg() — Multiples Funciones a la Vez\n",
    "\n",
    "`.agg()` te permite calcular varias estadisticas en una sola llamada,\n",
    "con nombres de columna personalizados."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 13,
   "id": "a52e0fe2",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "    ramo  polizas  prima_total  prima_prom  prima_max  siniest_tot\n",
      "0  Autos        3        12500     4166.67       5800            1\n",
      "1    GMM        3         7500     2500.00       3200            1\n",
      "2   Vida        2        16900     8450.00       9100            5\n"
     ]
    }
   ],
   "source": [
    "# ── .agg() basico ────────────────────────────────────────────────────────────\n",
    "resumen = cartera.groupby('ramo').agg(\n",
    "    polizas    = ('poliza',  'count'),\n",
    "    prima_total= ('prima',   'sum'),\n",
    "    prima_prom = ('prima',   'mean'),\n",
    "    prima_max  = ('prima',   'max'),\n",
    "    siniest_tot= ('siniest', 'sum')\n",
    ").round(2).reset_index()\n",
    "\n",
    "print(resumen.to_string())"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 14,
   "id": "ecdcbdda",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "       count    sum     mean      std  rango  coef_variacion\n",
      "ramo                                                        \n",
      "Autos      3  12500  4166.67  1601.04   3200            0.38\n",
      "GMM        3   7500  2500.00   655.74   1300            0.26\n",
      "Vida       2  16900  8450.00   919.24   1300            0.11\n"
     ]
    }
   ],
   "source": [
    "# ── .agg() con funcion propia ────────────────────────────────────────────────\n",
    "# Puedes pasar cualquier funcion como agregador\n",
    "\n",
    "def rango(x):\n",
    "    return x.max() - x.min()\n",
    "\n",
    "def coef_variacion(x):\n",
    "    return x.std() / x.mean() if x.mean() != 0 else 0\n",
    "\n",
    "analisis = cartera.groupby('ramo')['prima'].agg([\n",
    "    'count', 'sum', 'mean', 'std', rango, coef_variacion\n",
    "]).round(2)\n",
    "\n",
    "print(analisis)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 15,
   "id": "4dddce33",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "========================================================================\n",
      "  REPORTE POR RAMO — CARTERA DIPLOMADO\n",
      "========================================================================\n",
      " ramo  polizas  prima_total  prima_prom  siniest_tot  pct_prima  frec_prom\n",
      "Autos        3        12500     4166.67            1       33.9     0.3333\n",
      "  GMM        3         7500     2500.00            1       20.3     0.3333\n",
